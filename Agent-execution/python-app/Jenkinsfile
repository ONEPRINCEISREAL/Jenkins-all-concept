pipeline {
    agent { label 'worker-node' }

    stages {

        stage('Clone Github Repository') {
            steps {
                git branch: 'main',
                    changelog: false,
                    poll: false,
                    url: 'https://github.com/ONEPRINCEISREAL/Jenkins-all-concept.git'
                sh 'pwd'
            }
        }

        stage('Build') {
            steps {
                dir('python-jenkins-docker-app') {
                    sh 'python3 -m py_compile app.py'
                }
            }
        }

        stage('Test') {
            steps {
                dir('python-jenkins-docker-app') {
                    sh 'python3 -m unittest discover tests'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('python-jenkins-docker-app') {
                    sh 'docker build -t python-app:latest .'
                }
            }
        }

        stage('Docker Run') {
            steps {
                dir('python-jenkins-docker-app') {
                    sh 'docker run --rm python-app:latest'
                }
            }
        }

        stage('Docker Tag & Push') {
            steps {
                dir('python-jenkins-docker-app') {
                    withCredentials([usernamePassword(
                        credentialsId: 'kappapvt',
                        passwordVariable: 'DockerhubPassword',
                        usernameVariable: 'DockerhubUserName'
                    )]) {
                        sh '''
                            echo "$DockerhubPassword" | docker login -u "$DockerhubUserName" --password-stdin
                            docker tag python-app:latest kappapvt/python-app:latest
                            docker push kappapvt/python-app:latest
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}